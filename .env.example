# Copy this file to .env and fill in real values on your own computer.
# Never commit .env to GitHub.

APP_NAME=AI Knowledge Assistant
APP_ENV=development
APP_VERSION=0.1.0
SERVICE_NAME=ai-knowledge-assistant

# Database examples. Choose one later when we really connect a database.
DATABASE_URL=mysql+pymysql://USERNAME:PASSWORD@localhost:3306/ai_knowledge_assistant

# LLM provider examples. Fill these only when we start calling a model.
OPENAI_API_KEY=your_api_key_here
MODEL_NAME=gpt-4.1-mini
